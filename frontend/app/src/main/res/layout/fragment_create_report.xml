<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:clipToPadding="false">

        <TextView
            android:id="@+id/tvHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Yeni İhbar Oluştur"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="24dp" />

        <!-- Details Section -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Başlık"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            app:boxBackgroundColor="@color/white"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp"
            app:boxStrokeColor="@color/primary"
            android:layout_marginBottom="16dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:inputType="textCapSentences" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Açıklama"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            app:boxBackgroundColor="@color/white"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp"
            android:layout_marginBottom="24dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etDescription"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:gravity="top"
                android:inputType="textMultiLine|textCapSentences" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Category Section -->
        <TextView
            android:id="@+id/tvCategoryLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Kategori"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="8dp" />

        <RadioGroup
            android:id="@+id/rgCategory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <RadioButton
                android:id="@+id/rbReport"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="İhbar"
                android:textColor="@color/text_secondary"
                android:buttonTint="@color/category_report" />

            <Space android:layout_width="16dp" android:layout_height="wrap_content" />

            <RadioButton
                android:id="@+id/rbFeeding"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Besleme"
                android:textColor="@color/text_secondary"
                android:buttonTint="@color/category_feeding" />

            <Space android:layout_width="16dp" android:layout_height="wrap_content" />

            <RadioButton
                android:id="@+id/rbAdoption"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sahiplendirme"
                android:textColor="@color/text_secondary"
                android:buttonTint="@color/category_adoption" />
        </RadioGroup>

        <!-- Dynamic Types -->
        <TextView
            android:id="@+id/tvReportTypeLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="İhbar Türü"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="8dp" />

        <androidx.appcompat.widget.AppCompatSpinner
            android:id="@+id/spinnerReportType"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/abc_edit_text_material"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/tvAnimalTypeLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hayvan Türü"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="8dp" />

        <androidx.appcompat.widget.AppCompatSpinner
            android:id="@+id/spinnerAnimalType"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/abc_edit_text_material"
            android:layout_marginBottom="24dp" />

        <!-- Location Section -->
        <TextView
            android:id="@+id/tvLocationLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Konum"
            android:textStyle="bold"
            android:textColor="@color/text_primary" />

        <TextView
            android:id="@+id/tvLocationHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Haritadan seçmek için dokun"
            android:textSize="12sp"
            android:textColor="@color/text_hint"
            android:layout_marginBottom="8dp" />

        <androidx.cardview.widget.CardView
            android:id="@+id/cvMapContainer"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/surface_variant"
            android:layout_marginBottom="8dp">

            <FrameLayout
                android:id="@+id/mapContainer"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <fragment
                    android:id="@+id/mapFragment"
                    android:name="com.google.android.gms.maps.SupportMapFragment"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />

                <!-- Center Marker -->
                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_location"
                    app:tint="@color/error" />

                <!-- Click Interceptor (transparent) if needed to launch full map, but usage implies
                inline interaction -->
            </FrameLayout>
        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/tvSelectedLocation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Konum seçilmedi"
            android:gravity="center"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="24dp" />

        <!-- Photo Selection -->
        <TextView
            android:id="@+id/tvPhotoLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Fotoğraf (Opsiyonel)"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="100dp"
                android:layout_height="100dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/text_hint"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="@android:color/transparent">

                <ImageView
                    android:id="@+id/ivPhotoPreview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:background="@color/surface_variant"
                    android:visibility="gone" />

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="center"
                    android:src="@drawable/ic_add_photo"
                    app:tint="@color/text_hint"
                    android:padding="32dp" />

                <!-- Make the button cover the area effectively or act as the trigger -->
            </com.google.android.material.card.MaterialCardView>

            <Button
                android:id="@+id/btnSelectPhoto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FOTOĞRAF SEÇ"
                style="@style/Widget.PatiTakip.Button.Outlined"
                android:layout_marginStart="16dp" />
        </LinearLayout>

        <Button
            android:id="@+id/btnSubmit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="İHBARI OLUŞTUR"
            style="@style/Widget.PatiTakip.Button"
            android:textAllCaps="true"
            android:textSize="16sp" />

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="16dp"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>