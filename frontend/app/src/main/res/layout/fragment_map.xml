<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- Header Section -->
    <LinearLayout
        android:id="@+id/headerSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/white"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp"
        android:gravity="center_vertical"
        android:elevation="2dp"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Back Button -->
        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Geri"
            app:tint="@color/black" />

        <!-- Title -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Map"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:gravity="center" />

        <!-- Spacer for symmetry -->
        <View
            android:layout_width="40dp"
            android:layout_height="40dp" />

    </LinearLayout>

    <!-- Category Filter Chips -->
    <HorizontalScrollView
        android:id="@+id/filterScrollView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp"
        android:background="@color/white"
        app:layout_constraintTop_toBottomOf="@id/headerSection">

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupFilters"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            app:chipSpacingHorizontal="8dp">

            <!-- All Chip -->
            <com.google.android.material.chip.Chip
                android:id="@+id/chipAll"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🐾 All"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="13sp"
                app:chipBackgroundColor="@color/paw_green"
                app:chipCornerRadius="20dp"
                app:chipStrokeWidth="0dp"
                app:checkedIconVisible="false"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp" />

            <!-- Adoption Chip -->
            <com.google.android.material.chip.Chip
                android:id="@+id/chipAdoption"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🏠 Adoption"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:textSize="13sp"
                app:chipBackgroundColor="#F5F5F5"
                app:chipCornerRadius="20dp"
                app:chipStrokeWidth="0dp"
                app:checkedIconVisible="false"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp" />

            <!-- Feeding Chip -->
            <com.google.android.material.chip.Chip
                android:id="@+id/chipFeeding"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🍖 Feeding"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:textSize="13sp"
                app:chipBackgroundColor="#F5F5F5"
                app:chipCornerRadius="20dp"
                app:chipStrokeWidth="0dp"
                app:checkedIconVisible="false"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp" />

            <!-- Reporting Chip -->
            <com.google.android.material.chip.Chip
                android:id="@+id/chipReporting"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🚩 Reporting"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:textSize="13sp"
                app:chipBackgroundColor="#F5F5F5"
                app:chipCornerRadius="20dp"
                app:chipStrokeWidth="0dp"
                app:checkedIconVisible="false"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp" />

        </com.google.android.material.chip.ChipGroup>

    </HorizontalScrollView>

    <!-- Google Map -->
    <com.google.android.gms.maps.MapView
        android:id="@+id/mapView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/filterScrollView"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Floating Action Button -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddReport"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        android:src="@drawable/ic_add_photo"
        android:contentDescription="Gönderi Oluştur"
        app:tint="@color/white"
        app:backgroundTint="@color/paw_green"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:fabSize="normal"
        app:elevation="6dp" />

</androidx.constraintlayout.widget.ConstraintLayout>