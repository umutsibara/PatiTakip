<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.PatiTakip" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Brand Colors -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/accent</item>
        <item name="colorSecondary">@color/accent</item>

        <!-- Backgrounds -->
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>

        <!-- Typography -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>

        <!-- System UI -->
        <item name="android:statusBarColor">@color/primary</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
    </style>

    <style name="Theme.PatiTakip" parent="Base.Theme.PatiTakip" />

    <style name="Theme.PatiTakip.NoActionBar" parent="Theme.PatiTakip">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <!-- Modern Card Style -->
    <style name="Widget.PatiTakip.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">2dp</item>
        <item name="cardBackgroundColor">@color/card_background</item>
        <item name="strokeColor">#E0E0E0</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <!-- Rounded Button Style -->
    <style name="Widget.PatiTakip.Button" parent="Widget.Material3.Button">
        <item name="cornerRadius">12dp</item>
        <item name="android:paddingVertical">12dp</item>
    </style>

    <!-- Outlined Button Style -->
    <style name="Widget.PatiTakip.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="cornerRadius">12dp</item>
        <item name="strokeColor">@color/primary</item>
        <item name="android:textColor">@color/primary</item>
    </style>

    <!-- FAB Style -->
    <style name="Widget.PatiTakip.FAB" parent="Widget.Material3.FloatingActionButton.Primary">
        <item name="elevation">6dp</item>
        <item name="android:layout_margin">16dp</item>
        <item name="backgroundTint">@color/accent</item>
        <item name="tint">@color/white</item>
    </style>

    <!-- Filter Chip Style -->
    <style name="Widget.PatiTakip.Chip" parent="Widget.Material3.Chip.Filter">
        <item name="chipBackgroundColor">@color/surface</item>
        <item name="chipCornerRadius">20dp</item>
        <item name="android:elevation">4dp</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>
</resources>